# 飞书应用凭证（多表同步 - 主力使用）
# 在飞书开放平台 https://open.feishu.cn 创建自建应用获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 如有多账号需求，可取消注释以下备用凭证
# FEISHU_APP_ID_ALT=cli_xxxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET_ALT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书单表同步凭证（旧版脚本，已基本弃用）
# FEISHU_SINGLE_APP_ID=cli_xxxxxxxxxxxxxxxxx
# FEISHU_SINGLE_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
